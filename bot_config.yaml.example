# Telegram bot configuration
# Copy this file to bot_config.yaml and fill in your values

# Get your token from @BotFather on Telegram
telegram_bot_token: "YOUR_TELEGRAM_BOT_TOKEN_HERE"

# LLM settings for the bot
llm_api: "openai"                        # "openai" (LM Studio) or "ollama"
llm_url: "http://127.0.0.1:1234/v1"     # LM Studio default; use http://localhost:11434 for Ollama
llm_model: "local-model"                 # Model name as shown in LM Studio / Ollama
llm_openai_mode: "auto"                  # "auto", "chat", or "completions"
llm_timeout_sec: 1800                    # Timeout per LLM request (seconds)
